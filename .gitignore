```gitignore
#################################################
# Terraform
#################################################

.terraform/
*.tfstate
*.tfstate.*
terraform.tfvars
terraform.tfvars.json
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl

#################################################
# Lambda Build Artifacts
#################################################

lambda.zip
*.zip

#################################################
# Python
#################################################

__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.pytest_cache/
.mypy_cache/
.venv/
venv/
env/

#################################################
# IDE
#################################################

.vscode/
.idea/
*.swp
*.swo

#################################################
# OS Files
#################################################

.DS_Store
Thumbs.db

#################################################
# AWS Credentials
#################################################

.aws/
.env
.env.*
*.pem
*.key

#################################################
# Logs
#################################################

*.log
logs/

#################################################
# Misc
#################################################

coverage/
dist/
build/
```
